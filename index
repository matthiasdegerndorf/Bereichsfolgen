function prefix(name) {
  if (name.includes('RO-L')) return 'rol';
  if (name.includes('RO-S')) return 'ros';
  if (name.includes('MB'))   return 'mb';
  return 'rol';
}

function shortName(name) {
  return name
    .replace(/^1\.5\.[123] (?:RO-L|RO-S|MB) FF /, '')
    .trim();
}

function ffCode(name) {
  const m = name.match(/^(1\.5\.[123]) (RO-L|RO-S|MB)/);
  return m ? m[1] + ' ' + m[2] : '';
}

function chipClass(p) {
  return 'ff-chip chip-' + p;
}

const zones = Object.entries(DATA);
let activeFilter = null;
let expanded = new Set();
let searchVal = '';

function renderGrid() {
  const grid = document.getElementById('grid');
  const q = searchVal.toLowerCase();

  let visible = 0;
  grid.innerHTML = '';

  zones.forEach(([zoneName, zoneData], idx) => {
    const oertlich = zoneData.oertlich[0];
    const ortsteil = zoneData.ortsteil;
    const allFFs = [oertlich, ...ortsteil].map(f => f ? f.name : '');

    // Filter by search
    if (q) {
      const inZone = zoneName.toLowerCase().includes(q);
      const inFF = allFFs.some(f => f.toLowerCase().includes(q));
      if (!inZone && !inFF) return;
    }

    // Filter by prefix (active filter on örtlich FF)
    if (activeFilter && oertlich) {
      if (prefix(oertlich.name) !== activeFilter) return;
    }

    visible++;
    const isExpanded = expanded.has(zoneName);
    const op = oertlich ? prefix(oertlich.name) : 'rol';
    const isElb = zoneName.includes('ELB ') || zoneName.includes('MISCHGEBIET');

    const card = document.createElement('div');
    card.className = 'zone-card' + (isExpanded ? ' expanded' : '') + (isElb ? ' elb-zone' : '');
    card.dataset.zone = zoneName;

    // Head
    const oertlichChip = oertlich
      ? `<span class="${chipClass(op)}" title="${oertlich.name}">${shortName(oertlich.name)}</span>`
      : '<span class="ff-chip" style="color:var(--muted)">–</span>';

    card.innerHTML = `
      <div class="card-head">
        <div class="zone-num">${idx+1}</div>
        <div class="card-info">
          <div class="zone-name">${zoneName}</div>
          <div class="oertlich-row">
            <span class="label-tag label-oertlich">Örtlich</span>
            ${oertlichChip}
          </div>
        </div>
        <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    `;

    // Body
    if (ortsteil.length > 0) {
      const body = document.createElement('div');
      body.className = 'card-body';

      const MAX_INIT = 10;
      let showAll = false;

      function buildList() {
        body.innerHTML = `<div class="section-title">Bereichsfolge Ortsteil</div>`;
        const list = document.createElement('div');
        list.className = 'ff-list';
        const slice = showAll ? ortsteil : ortsteil.slice(0, MAX_INIT);
        slice.forEach(ff => {
          const p = prefix(ff.name);
          const row = document.createElement('div');
          row.className = 'ff-row';
          row.innerHTML = `
            <span class="ff-row-nr">${ff.nr}</span>
            <span class="ff-row-dot dot-${p}"></span>
            <span class="ff-row-name">${shortName(ff.name)}</span>
            <span class="ff-row-code">${ffCode(ff.name)}</span>
          `;
          list.appendChild(row);
        });
        body.appendChild(list);
        if (ortsteil.length > MAX_INIT) {
          const btn = document.createElement('button');
          btn.className = 'show-more-btn';
          btn.textContent = showAll
            ? '▲ Weniger anzeigen'
            : `▼ Alle ${ortsteil.length} anzeigen`;
          btn.onclick = (e) => {
            e.stopPropagation();
            showAll = !showAll;
            buildList();
          };
          body.appendChild(btn);
        }
      }

      buildList();
      card.appendChild(body);
    } else {
      const body = document.createElement('div');
      body.className = 'card-body';
      body.innerHTML = '<div style="color:var(--muted);font-size:0.76rem;padding:4px 8px">Keine Ortsteil-Folge hinterlegt</div>';
      card.appendChild(body);
    }

    card.querySelector('.card-head').addEventListener('click', () => {
      if (expanded.has(zoneName)) {
        expanded.delete(zoneName);
        card.classList.remove('expanded');
      } else {
        expanded.add(zoneName);
        card.classList.add('expanded');
      }
    });

    grid.appendChild(card);
  });

  document.getElementById('stat-visible').textContent = visible;

  if (visible === 0) {
    const msg = document.createElement('div');
    msg.id = 'no-results';
    msg.style.display = 'block';
    msg.innerHTML = `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg><br>Keine Zonen gefunden`;
    grid.appendChild(msg);
  }
}

// Search
document.getElementById('search').addEventListener('input', e => {
  searchVal = e.target.value;
  renderGrid();
});

// Filter buttons
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const f = btn.dataset.filter;
    if (activeFilter === f) {
      activeFilter = null;
      btn.className = 'filter-btn';
    } else {
      activeFilter = f;
      document.querySelectorAll('.filter-btn').forEach(b => b.className = 'filter-btn');
      btn.classList.add('active-' + f);
    }
    renderGrid();
  });
});

renderGrid();
</script>
</body>
</html>