<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bereichsfolge Brannenburg RO-L</title>
<style>
  :root {
    --bg: #0f1117;
    --surface: #1a1d27;
    --surface2: #222636;
    --border: #2e3348;
    --text: #e8eaf0;
    --muted: #8b90a8;
    --rol: #3b82f6;
    --rol-bg: #1e3a5f;
    --rol-muted: #93c5fd;
    --ros: #10b981;
    --ros-bg: #064e3b;
    --ros-muted: #6ee7b7;
    --mb: #f59e0b;
    --mb-bg: #78350f;
    --mb-muted: #fcd34d;
    --accent: #6366f1;
    --accent-glow: rgba(99,102,241,0.15);
    --radius: 10px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* HEADER */
  header {
    background: linear-gradient(135deg, #1a1d27 0%, #151824 100%);
    border-bottom: 1px solid var(--border);
    padding: 20px 24px 16px;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(8px);
  }
  .header-top {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }
  .logo {
    width: 38px; height: 38px;
    background: linear-gradient(135deg, var(--accent), #8b5cf6);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
    box-shadow: 0 0 20px var(--accent-glow);
  }
  .title-block h1 {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #fff;
  }
  .title-block p {
    font-size: 0.72rem;
    color: var(--muted);
    margin-top: 1px;
  }

  /* CONTROLS */
  .controls {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 200px;
  }
  .search-wrap svg {
    position: absolute;
    left: 11px; top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    pointer-events: none;
  }
  #search {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-size: 0.85rem;
    padding: 8px 12px 8px 36px;
    outline: none;
    transition: border-color .2s;
  }
  #search:focus { border-color: var(--accent); }
  #search::placeholder { color: var(--muted); }

  .filter-btns {
    display: flex;
    gap: 6px;
  }
  .filter-btn {
    padding: 7px 13px;
    border-radius: 7px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .15s;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .filter-btn:hover { border-color: var(--accent); color: var(--text); }
  .filter-btn.active-rol { background: var(--rol-bg); border-color: var(--rol); color: var(--rol-muted); }
  .filter-btn.active-ros { background: var(--ros-bg); border-color: var(--ros); color: var(--ros-muted); }
  .filter-btn.active-mb  { background: var(--mb-bg);  border-color: var(--mb);  color: var(--mb-muted); }

  .stats-bar {
    display: flex;
    gap: 16px;
    margin-top: 10px;
    font-size: 0.72rem;
    color: var(--muted);
  }
  .stats-bar span b { color: var(--text); }

  /* GRID */
  main {
    padding: 20px 20px 40px;
    max-width: 1400px;
    margin: 0 auto;
  }
  #grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    gap: 14px;
  }
  .zone-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color .2s, box-shadow .2s;
    cursor: pointer;
  }
  .zone-card:hover {
    border-color: #3e4460;
    box-shadow: 0 4px 24px rgba(0,0,0,0.4);
  }
  .zone-card.expanded {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent), 0 4px 24px rgba(99,102,241,0.2);
  }

  /* CARD HEADER */
  .card-head {
    padding: 13px 15px 12px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    user-select: none;
  }
  .zone-num {
    width: 26px; height: 26px;
    border-radius: 6px;
    background: var(--surface2);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--muted);
    flex-shrink: 0;
    margin-top: 1px;
  }
  .card-info { flex: 1; min-width: 0; }
  .zone-name {
    font-size: 0.87rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 5px;
    line-height: 1.3;
  }
  .oertlich-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .label-tag {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .label-oertlich {
    background: rgba(99,102,241,0.2);
    color: #a5b4fc;
    border: 1px solid rgba(99,102,241,0.3);
  }
  .ff-chip {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
  }
  .chip-rol { background: var(--rol-bg); color: var(--rol-muted); border: 1px solid rgba(59,130,246,0.3); }
  .chip-ros { background: var(--ros-bg); color: var(--ros-muted); border: 1px solid rgba(16,185,129,0.3); }
  .chip-mb  { background: var(--mb-bg);  color: var(--mb-muted);  border: 1px solid rgba(245,158,11,0.3); }

  .chevron {
    margin-left: auto;
    flex-shrink: 0;
    color: var(--muted);
    transition: transform .2s;
    align-self: center;
  }
  .zone-card.expanded .chevron { transform: rotate(180deg); }

  /* CARD BODY */
  .card-body {
    display: none;
    border-top: 1px solid var(--border);
    padding: 12px 15px 14px;
    background: rgba(0,0,0,0.15);
  }
  .zone-card.expanded .card-body { display: block; }

  .section-title {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .ff-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .ff-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 8px;
    border-radius: 6px;
    transition: background .1s;
  }
  .ff-row:hover { background: rgba(255,255,255,0.03); }
  .ff-row-nr {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--muted);
    width: 20px;
    text-align: right;
    flex-shrink: 0;
  }
  .ff-row-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-rol { background: var(--rol); }
  .dot-ros { background: var(--ros); }
  .dot-mb  { background: var(--mb); }
  .ff-row-name {
    font-size: 0.76rem;
    color: var(--text);
    flex: 1;
    min-width: 0;
  }
  .ff-row-code {
    font-size: 0.62rem;
    color: var(--muted);
    flex-shrink: 0;
  }

  .show-more-btn {
    background: none;
    border: 1px dashed var(--border);
    color: var(--muted);
    font-size: 0.72rem;
    cursor: pointer;
    padding: 5px 10px;
    border-radius: 6px;
    margin-top: 6px;
    width: 100%;
    transition: all .15s;
  }
  .show-more-btn:hover { border-color: var(--accent); color: var(--accent); }

  /* LEGEND */
  .legend {
    display: flex;
    gap: 14px;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    color: var(--muted);
  }
  .legend-dot {
    width: 9px; height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* NO RESULTS */
  #no-results {
    display: none;
    text-align: center;
    padding: 60px 20px;
    color: var(--muted);
    font-size: 0.9rem;
    grid-column: 1/-1;
  }
  #no-results svg { opacity: 0.3; margin-bottom: 12px; }

  /* ELB zones special */
  .zone-card.elb-zone .card-head { border-left: 3px solid rgba(99,102,241,0.5); }

  @media (max-width: 600px) {
    header { padding: 14px 14px 12px; }
    main { padding: 12px 10px 40px; }
    #grid { gap: 10px; grid-template-columns: 1fr; }
    .filter-btns { display: none; }
  }
</style>
</head>
